{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"printWidth": 80,
	"tabWidth": 2,
	"ignorePatterns": [
		"convex/_generated/**",
		"bun.lock",
		"src/routeTree.gen.ts"
	],
	"sortImports": {
		"newlinesBetween": false
	},
	"sortTailwindcss": {
		"stylesheet": "./src/styles.css",
		"functions": ["clsx", "cn"]
	}
}
